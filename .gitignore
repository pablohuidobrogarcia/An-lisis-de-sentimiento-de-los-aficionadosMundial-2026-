# ── Environment ──────────────────────────────────────────────────────────────
.env
venv/
.venv/
miniconda3/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Notebooks ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ── Data ─────────────────────────────────────────────────────────────────────
# Raw collected data (parquet/csv) and checkpoint files ARE tracked.
# Required for the daily GitHub Actions collection workflow to commit
# newly collected data and persist checkpoint state across runs.
# See data_collection.py: COMMENTS_FILE, CHECKPOINT_FILE, etc.

# data/processed/ is intentionally ignored because it is regenerable
# from data/raw/ + notebooks. Keeping it out of git avoids bloating
# the repository with derived artifacts.
data/processed/*
!data/processed/.gitkeep
# Track sentiment results so CI can do incremental BERT inference
# instead of processing the full dataset every run (~7 MB parquet).
!data/processed/comentarios_sentimiento/
data/processed/comentarios_sentimiento/*
!data/processed/comentarios_sentimiento/comentarios_sentimiento.parquet

# ── Models ───────────────────────────────────────────────────────────────────
models/
*.bin
*.pt
*.pth
*.safetensors

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Credential / secret files ────────────────────────────────────────────────
.env
.env.local
.env.*.local
credentials.json
*.pem
*.key
service-account*.json
client-secret*.json
.streamlit/secrets.toml

# Secrets baseline for detect-secrets (auto-generated, safe to commit)
!.secrets.baseline
